# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── OpenDental MySQL ───────────────────────────────────────────────────────────
# Option A: individual fields
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=opendental

# Option B: connection URL (overrides individual fields above if set)
# DB_URL=mysql://root:your_password_here@localhost:3306/opendental

# ── Zoom Incoming Webhook ─────────────────────────────────────────────────────
# Create one at: Zoom Marketplace → Develop → Build App → Incoming Webhook
# Paste the webhook URL here.
ZOOM_WEBHOOK_URL=https://inapi.zoom.us/v1/hooks/...
