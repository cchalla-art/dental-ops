# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── OpenDental MySQL ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=opendental

# ── Zoom Incoming Webhook ─────────────────────────────────────────────────────
# Get these from: Zoom desktop app → your channel → Integrations → Incoming Webhook
# The URL and token are both shown when you set up the webhook.
ZOOM_WEBHOOK_URL=https://integrations.zoom.us/chat/webhooks/incomingwebhook/YOUR_ID_HERE
ZOOM_WEBHOOK_TOKEN=your_verification_token_here
